{
  "name": "pi-scope",
  "version": "0.7.0",
  "description": "AST-powered context, retrieval, and code intelligence for pi — fully independent, no external Python dependencies",
  "type": "module",
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "keywords": [
    "pi",
    "pi-coding-agent",
    "ast",
    "context",
    "retrieval",
    "skeleton",
    "hashline",
    "lsp",
    "code-intelligence",
    "graph-analysis",
    "god-nodes",
    "community-detection",
    "cycle-detection"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "ignore": "^6.0.2",
    "jsonc-parser": "^3.3.1",
    "pi-telemetry": "github:dmoreq/pi-telemetry",
    "tree-sitter": "^0.22.4",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-typescript": "^0.23.2",
    "vscode-jsonrpc": "^3.6.2",
    "xxhash-wasm": "^1.1.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@mariozechner/pi-tui": "^0.72.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist/",
    "algorithms/",
    "context/",
    "hashline/",
    "indexer/",
    "lsp/",
    "metrics/",
    "parsers/",
    "persistence/",
    "plugins/",
    "services/",
    "shared/",
    "skills/",
    "tools/",
    "ui/",
    "visualization/",
    "extension.ts",
    "manager.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ],
    "skills": {
      "pi-scope": "./skills/pi-scope/SKILL.md",
      "pi-scope-config": "./skills/pi-scope-config/SKILL.md",
      "pi-scope-hashline": "./skills/pi-scope-hashline/SKILL.md",
      "pi-scope-lsp": "./skills/pi-scope-lsp/SKILL.md",
      "pi-scope-parsers": "./skills/pi-scope-parsers/SKILL.md",
      "pi-scope-plugins": "./skills/pi-scope-plugins/SKILL.md",
      "pi-scope-retrieval": "./skills/pi-scope-retrieval/SKILL.md",
      "pi-scope-telemetry": "./skills/pi-scope-telemetry/SKILL.md"
    }
  }
}
